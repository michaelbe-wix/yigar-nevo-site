# Wix Managed Headless credentials — used by the Wix CLI to build & deploy.
#
# These are normally provisioned for you by the Wix CLI during project setup
# (`wix login` / project connect), which writes the real values to `.env.local`.
# `.env.local` is git-ignored and MUST NOT be committed — it contains a secret.
#
# Copy this file to `.env.local` and fill in the values from your Wix project
# if they are not generated automatically.

WIX_CLOUD_PROVIDER=
WIX_CLIENT_ID=
WIX_CLIENT_INSTANCE_ID=
WIX_CLIENT_PUBLIC_KEY=
WIX_CLIENT_SECRET=
